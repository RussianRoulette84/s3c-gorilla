#!/bin/bash
##########################################################################################
## otp-gorilla - show/copy OTP codes from KeePassXC, chip-wrapped
## Part of s3c-gorilla. Boot-time: master pw → enumerate 2FA/ → chip-wrap
## each secret. Runtime: Touch ID unwrap → compute TOTP → display + copy +
## macOS notification.
##
## Usage:
##   otp-gorilla              # show all OTP codes (lazy-wraps all 2FA entries)
##   otp-gorilla atlas        # fuzzy-match: "atlas" → "Atlassian"
##   otp-gorilla --clear      # wipe all OTP blobs from /tmp
##########################################################################################

GORILLA_CONFIG="$HOME/.config/s3c-gorilla/config"
[[ -f "$GORILLA_CONFIG" ]] && source "$GORILLA_CONFIG"

: "${GORILLA_DB:=$HOME/Library/Mobile Documents/com~apple~CloudDocs/gorilla_tunnel.dat.kdbx}"
: "${GORILLA_OTP_GROUP:=2FA}"
: "${GORILLA_TOUCHID:=/usr/local/bin/touchid-gorilla}"
: "${GORILLA_BANNERS:=/usr/local/share/s3c-gorilla/banners.sh}"
: "${GORILLA_NOTIFIER:=terminal-notifier}"
[[ -r "$GORILLA_BANNERS" ]] && source "$GORILLA_BANNERS"
# Fallback when banners.sh is absent: session-unlock degrades to a plain prompt.
command -v get_master_pw >/dev/null || get_master_pw() { ask_master_pw; }

# --paranoid (CP3): never wrap /tmp blobs — compute the code via KeePassXC per call (same as
# password mode), even on a Touch ID machine. Off by default. Pull it out of the args.
: "${GORILLA_PARANOID:=false}"
PARANOID=false; [[ "$GORILLA_PARANOID" == "true" ]] && PARANOID=true
_args=(); for _a in "$@"; do [[ "$_a" == "--paranoid" ]] && { PARANOID=true; continue; }; _args+=("$_a"); done
set -- "${_args[@]}"
$PARANOID && command -v _paranoid_wipe >/dev/null 2>&1 && _paranoid_wipe   # clear cached blobs (#7/#10)

# ----------------------------------------------------------
# Helpers
# ----------------------------------------------------------

ask_master_pw() {
    command -v show_master_banner &>/dev/null && show_master_banner
    local _t="${GORILLA_TOUCHID:-/usr/local/bin/touchid-gorilla}" spw
    if [[ -x "$_t" ]] && spw=$("$_t" master-prompt "master password" 2>/dev/tty) && [[ -n "$spw" ]]; then
        printf '%s' "$spw"; return   # secure keyboard entry (H4)
    fi
    local pw
    printf '🔐 KeePass master password: ' >&2
    read -rs pw
    printf '\n' >&2
    printf '%s' "$pw"
}

# True only when the Secure Enclave helper is installed (Touch ID machines).
# Without it we run password-only: let KeePassXC compute the TOTP itself.
have_chip() { [[ -x "$GORILLA_TOUCHID" ]]; }

# Password mode — no chip, no /tmp blobs. One master-pw prompt, then KeePassXC
# computes each entry's live TOTP via `show -t`. Mirrors the chip dispatch:
# no arg = list all codes, an arg = fuzzy-match one (copy + notify).
run_password_mode() {
    local arg="$1" pw="" services svc code matches=() q_lower s_lower use_agent=false
    # Prefer the session agent: it lists + computes TOTP itself, so the master pw
    # never enters this shell (B1). Fall back to the direct pw path otherwise.
    if [[ "$GORILLA_SESSION_UNLOCK" == "true" ]] && command -v session_unlock >/dev/null 2>&1 && session_unlock; then
        use_agent=true
        services=$(session_list "$GORILLA_OTP_GROUP" 2>/dev/null | grep -v '/$')
    else
        pw=$(get_master_pw)
        [[ -z "$pw" ]] && { echo "otp-gorilla: no password entered" >&2; return 1; }
        services=$(echo "$pw" | keepassxc-cli ls "$GORILLA_DB" "$GORILLA_OTP_GROUP/" -q 2>/dev/null | grep -v '/$')
    fi
    if [[ -z "$services" ]]; then
        echo "otp-gorilla: no entries in $GORILLA_OTP_GROUP/" >&2; unset pw; return 1
    fi

    # Live TOTP for one service — via the agent (pw stays inside) or direct.
    _otp_code() {
        if $use_agent; then session_extract otp "$GORILLA_OTP_GROUP/$1" 2>/dev/null
        else echo "$pw" | keepassxc-cli show -t "$GORILLA_DB" "$GORILLA_OTP_GROUP/$1" -q 2>/dev/null; fi
    }

    if [[ -z "$arg" ]]; then
        echo "All OTP codes:"
        echo "────────────────────────────────"
        while IFS= read -r svc; do
            [[ -z "$svc" ]] && continue
            code=$(_otp_code "$svc")
            printf "  %-24s  %s\n" "$svc" "${code:-—}"
        done <<< "$services"
        echo "────────────────────────────────"
        unset pw; return 0
    fi

    q_lower=$(echo "$arg" | tr '[:upper:]' '[:lower:]')
    while IFS= read -r svc; do
        [[ -z "$svc" ]] && continue
        s_lower=$(echo "$svc" | tr '[:upper:]' '[:lower:]')
        [[ "$s_lower" == *"$q_lower"* ]] && matches+=("$svc")
    done <<< "$services"
    if [[ ${#matches[@]} -eq 0 ]]; then
        echo "otp-gorilla: no match for '$arg'. Available:" >&2
        echo "$services" | sed 's/^/  /' >&2; unset pw; return 1
    elif [[ ${#matches[@]} -gt 1 ]]; then
        echo "otp-gorilla: multiple matches for '$arg':" >&2
        printf '  %s\n' "${matches[@]}" >&2; unset pw; return 1
    fi
    svc="${matches[0]}"
    code=$(_otp_code "$svc")
    unset pw
    if [[ -z "$code" ]]; then
        echo "otp-gorilla: no TOTP configured for $svc" >&2; return 1
    fi
    echo "$svc: $code"
    printf '%s' "$code" | pbcopy
    command -v "$GORILLA_NOTIFIER" &>/dev/null && "$GORILLA_NOTIFIER" -title "OTP: $svc" -message "$code" &>/dev/null
}

# keepassxc-cli show returns the value of an attribute. Try both known TOTP
# attribute names (newer "otp" → otpauth URI; older "TOTP-Secret" → base32).
kdbx_extract_totp_value() {
    local pw="$1"
    local entry="$2"
    local v
    v=$(echo "$pw" | keepassxc-cli show "$GORILLA_DB" "$GORILLA_OTP_GROUP/$entry" -a otp -q 2>/dev/null)
    if [[ -n "$v" && "$v" != "ERROR"* ]]; then
        printf '%s' "$v"; return 0
    fi
    v=$(echo "$pw" | keepassxc-cli show "$GORILLA_DB" "$GORILLA_OTP_GROUP/$entry" -a TOTP-Secret -q 2>/dev/null)
    if [[ -n "$v" && "$v" != "ERROR"* ]]; then
        printf '%s' "$v"; return 0
    fi
    return 1
}

bootstrap_all() {
    local pw
    pw=$(get_master_pw)
    [[ -z "$pw" ]] && return 1
    local services
    services=$(echo "$pw" | keepassxc-cli ls "$GORILLA_DB" "$GORILLA_OTP_GROUP/" -q 2>/dev/null | grep -v '/$')
    if [[ -z "$services" ]]; then
        echo "otp-gorilla: no entries in $GORILLA_OTP_GROUP/" >&2
        unset pw
        return 1
    fi
    local count=0 svc val
    while IFS= read -r svc; do
        [[ -z "$svc" ]] && continue
        val=$(kdbx_extract_totp_value "$pw" "$svc")
        [[ -z "$val" ]] && continue
        printf '%s' "$val" | "$GORILLA_TOUCHID" wrap "otp-$svc" &>/dev/null && count=$((count+1))
    done <<< "$services"
    # Our otp blobs are written — fan out env + ssh in the BACKGROUND (skips fresh otp blobs),
    # so they need no second master-pw prompt this session and we don't block here (#3/#4).
    command -v fan_out_all >/dev/null 2>&1 && fan_out_all "$pw" &
    unset pw val
    echo "otp-gorilla: wrapped $count service(s) for this boot" >&2
    [[ $count -gt 0 ]]
}

list_wrapped() {
    shopt -s nullglob
    local f base
    for f in /tmp/s3c-gorilla/otp-*.blob; do
        base=$(basename "$f" .blob)
        echo "${base#otp-}"
    done
}

# Case-insensitive substring match against wrapped services.
# stdout = single matched name; stderr = multi-match guidance; exit 0 if exactly 1 match.
fuzzy_match() {
    local q="$1"
    local q_lower
    q_lower=$(echo "$q" | tr '[:upper:]' '[:lower:]')
    local matches=() svc s_lower
    while IFS= read -r svc; do
        s_lower=$(echo "$svc" | tr '[:upper:]' '[:lower:]')
        [[ "$s_lower" == *"$q_lower"* ]] && matches+=("$svc")
    done < <(list_wrapped)
    if [[ ${#matches[@]} -eq 0 ]]; then
        return 1
    elif [[ ${#matches[@]} -eq 1 ]]; then
        printf '%s' "${matches[0]}"
        return 0
    else
        echo "otp-gorilla: multiple matches for '$q':" >&2
        printf '  %s\n' "${matches[@]}" >&2
        return 1
    fi
}

show_one() {
    local svc="$1"
    local val code
    command -v show_touchid &>/dev/null && show_touchid   # bishop walk in background
    val=$("$GORILLA_TOUCHID" unwrap "otp-$svc" 2>/dev/null)
    command -v stop_touchid &>/dev/null && stop_touchid    # auto-stop on scan return
    if [[ -z "$val" ]]; then
        echo "otp-gorilla: unwrap cancelled or blob missing for $svc" >&2
        return 1
    fi
    code=$("$GORILLA_TOUCHID" totp "$val" 2>/dev/null)
    unset val
    if [[ -z "$code" ]]; then
        echo "otp-gorilla: failed to compute TOTP for $svc" >&2
        return 1
    fi
    echo "$svc: $code"
    printf '%s' "$code" | pbcopy
    if command -v "$GORILLA_NOTIFIER" &>/dev/null; then
        "$GORILLA_NOTIFIER" -title "OTP: $svc" -message "$code" &>/dev/null
    fi
}

# ----------------------------------------------------------
# Dispatch
# ----------------------------------------------------------

if [[ "$1" == "--clear" ]]; then
    shopt -s nullglob
    count=0
    for f in /tmp/s3c-gorilla/otp-*.blob; do
        trash "$f" 2>/dev/null || mv "$f" "$f.removed" 2>/dev/null
        count=$((count + 1))
    done
    echo "otp-gorilla: cleared $count otp blob(s)"
    exit 0
fi

# No Secure Enclave → password mode (KeePassXC computes the TOTP). Handles both
# the no-arg list and the fuzzy-match-one cases, then exits.
if ! have_chip || $PARANOID; then
    run_password_mode "$1"
    exit $?
fi

# No args: lazy-wrap-all + show all codes
if [[ -z "$1" ]]; then
    # Re-bootstrap when there are no wrapped blobs OR the session is stale (pre-boot, P2).
    if [[ -z "$(list_wrapped)" ]] || { command -v _blob_fresh >/dev/null 2>&1 && ! _blob_fresh "$GORILLA_SENTINEL"; }; then
        bootstrap_all || exit 1
    fi
    echo "All OTP codes:"
    echo "────────────────────────────────"
    command -v show_touchid &>/dev/null && show_touchid   # bishop walk in background
    while IFS= read -r svc; do
        [[ -z "$svc" ]] && continue
        val=$("$GORILLA_TOUCHID" unwrap "otp-$svc" 2>/dev/null)
        code=$("$GORILLA_TOUCHID" totp "$val" 2>/dev/null)
        unset val
        printf "  %-24s  %s\n" "$svc" "${code:-—}"
    done < <(list_wrapped)
    command -v stop_touchid &>/dev/null && stop_touchid    # auto-stop after last code
    echo "────────────────────────────────"
    exit 0
fi

# With arg: fuzzy match
if [[ -z "$(list_wrapped)" ]]; then
    bootstrap_all || exit 1
fi
matched=$(fuzzy_match "$1")
if [[ -z "$matched" ]]; then
    # Maybe new services added since last boot — re-bootstrap
    bootstrap_all || exit 1
    matched=$(fuzzy_match "$1")
fi
if [[ -z "$matched" ]]; then
    echo "otp-gorilla: no match for '$1'. Available:" >&2
    list_wrapped | sed 's/^/  /' >&2
    exit 1
fi
show_one "$matched"
