#!/bin/bash
##########################################################################################
## env-gorilla - inject .env secrets from KeePassXC into any process
## Part of s3c-gorilla. Uses touchid-gorilla chip-wrap primitives: master pw
## is typed once per boot per project, then Touch ID unwraps on reruns.
##
## Usage:
##   env-gorilla <project> -- <command>
##   env-gorilla <p1>,<p2>,<p3> -- <command>     # merge several .envs into ONE blob
##   env-gorilla --list                           # show available projects
##   env-gorilla --clear                          # wipe all env blobs from /tmp
##   env-gorilla --clear <project[,<p2>,...]>     # wipe one (combined) blob
##
## Multi-project mode merges every listed project's .env into a single
## chip-wrapped blob keyed by the sorted joined name (e.g. a+b+c.blob),
## so one Touch ID unlocks the whole set on subsequent runs. The user's
## listed order controls duplicate-key precedence (later projects win).
##########################################################################################

GORILLA_CONFIG="$HOME/.config/s3c-gorilla/config"
[[ -f "$GORILLA_CONFIG" ]] && source "$GORILLA_CONFIG"

: "${GORILLA_DB:=$HOME/Library/Mobile Documents/com~apple~CloudDocs/gorilla_tunnel.dat.kdbx}"
: "${GORILLA_ENV_GROUP:=ENV}"
: "${GORILLA_TOUCHID:=/usr/local/bin/touchid-gorilla}"
: "${GORILLA_BANNERS:=/usr/local/share/s3c-gorilla/banners.sh}"
[[ -r "$GORILLA_BANNERS" ]] && source "$GORILLA_BANNERS"

# ----------------------------------------------------------
# Helpers
# ----------------------------------------------------------

# True only when the Secure Enclave helper is actually installed. The installer
# drops touchid-gorilla into place only on machines with a working SE, so its
# presence is our mode signal. Without it we run password-only: extract from
# kdbx on every call, no /tmp blob cache, no Touch ID — just the master pw.
have_chip() { [[ -x "$GORILLA_TOUCHID" ]]; }

# Sort + dedupe a comma-separated project list, return it joined with '+'.
# Example:  "slav-ai,llm-docker"  →  "llm-docker+slav-ai"
# Same input in different order maps to the same key, so the cached blob
# is reused regardless of how the caller orders the projects.
normalize_project_list() {
    echo "$1" | tr ',' '\n' | sed '/^[[:space:]]*$/d' | sort -u | tr '\n' '+' | sed 's/+$//'
}

# Iterate a comma-separated project list in the caller's original order
# (not sorted). Used when fetching .envs so the caller's later entries
# override earlier ones for duplicate keys.
iter_project_list() {
    echo "$1" | tr ',' '\n' | sed '/^[[:space:]]*$/d'
}

ask_master_pw() {
    command -v show_master_banner &>/dev/null && show_master_banner
    local pw
    printf '🔐 KeePass master password: ' >&2
    read -rs pw
    printf '\n' >&2
    printf '%s' "$pw"
}

kdbx_extract_env() {
    local pw="$1"
    local project="$2"
    echo "$pw" | keepassxc-cli attachment-export \
        "$GORILLA_DB" "$GORILLA_ENV_GROUP/$project" .env --stdout -q 2>/dev/null
}

unwrap_blob() {
    local key="$1" out
    command -v show_touchid &>/dev/null && show_touchid   # bishop walk in background
    out=$("$GORILLA_TOUCHID" unwrap "env-$key" 2>/dev/null)
    command -v stop_touchid &>/dev/null && stop_touchid    # auto-stop on scan return
    printf '%s' "$out"
}

# Fetch + merge .envs for every project in the comma list under a single
# master-password prompt, wrap the merged result into a chip-blob keyed
# by the normalized name, then echo the merged stream.
bootstrap_and_get() {
    local project_list="$1"
    local key="$2"
    local pw merged env_data proj missing=()

    pw=$(ask_master_pw)
    [[ -z "$pw" ]] && { echo "env-gorilla: no password entered" >&2; return 1; }

    merged=""
    while IFS= read -r proj; do
        env_data=$(kdbx_extract_env "$pw" "$proj")
        if [[ -z "$env_data" ]]; then
            missing+=("$proj")
            continue
        fi
        if [[ -n "$merged" ]]; then
            merged+=$'\n'
        fi
        merged+="$env_data"
    done < <(iter_project_list "$project_list")

    # Warn about any missing kdbx entries but continue if at least one
    # project loaded — saves the user from a typo nuking the whole launch.
    if (( ${#missing[@]} > 0 )); then
        echo "env-gorilla: warning — couldn't extract $GORILLA_ENV_GROUP/{$(IFS=,; echo "${missing[*]}")}/.env (skipped)" >&2
    fi

    if [[ -z "$merged" ]]; then
        echo "env-gorilla: no .env data extracted from any listed project" >&2
        unset pw
        return 1
    fi

    # Cache into a chip-wrapped blob only when an SE is present. In password
    # mode we skip the wrap and just hand back the merged env — the master pw
    # prompt above is the only gate, re-asked on each run (no secure cache).
    if have_chip; then
        if ! printf '%s' "$merged" | "$GORILLA_TOUCHID" wrap "env-$key" &>/dev/null; then
            echo "env-gorilla: failed to chip-wrap env blob" >&2
            unset pw merged
            return 1
        fi
    fi
    unset pw
    printf '%s' "$merged"
    unset merged
}

get_env() {
    local project_list="$1"
    local key
    key=$(normalize_project_list "$project_list")
    if [[ -z "$key" ]]; then
        echo "env-gorilla: empty project list" >&2
        return 1
    fi
    # Password-only mode: no chip to unwrap/cache with — extract fresh each run.
    if ! have_chip; then
        bootstrap_and_get "$project_list" "$key"
        return
    fi

    local blob_path="/tmp/s3c-gorilla/env-$key.blob"
    local env_data

    if [[ -f "$blob_path" ]]; then
        env_data=$(unwrap_blob "$key")
        if [[ -n "$env_data" ]]; then
            printf '%s' "$env_data"
            return 0
        fi
        echo "env-gorilla: Touch ID cancelled or blob corrupted — re-bootstrapping" >&2
    fi
    bootstrap_and_get "$project_list" "$key"
}

# ----------------------------------------------------------
# Dispatch
# ----------------------------------------------------------

if [[ "$1" == "--list" ]]; then
    echo "Available projects:"
    pw=$(ask_master_pw)
    echo "$pw" | keepassxc-cli ls "$GORILLA_DB" "$GORILLA_ENV_GROUP/" -q 2>/dev/null | grep -v '/$'
    unset pw
    exit 0
fi

if [[ "$1" == "--clear" ]]; then
    if [[ -n "$2" ]]; then
        clear_key=$(normalize_project_list "$2")
        "$GORILLA_TOUCHID" wrap-clear "env-$clear_key"
        echo "Cleared env-$clear_key.blob"
        unset clear_key
    else
        shopt -s nullglob
        for f in /tmp/s3c-gorilla/env-*.blob; do
            trash "$f" 2>/dev/null || mv "$f" "$f.removed" 2>/dev/null
            echo "Cleared $(basename "$f")"
        done
    fi
    exit 0
fi

if [[ $# -lt 3 || "$*" != *" -- "* ]]; then
    cat << 'EOF'
env-gorilla — secrets from the vault, not from the disk

Usage:
  env-gorilla <project> -- <command>
  env-gorilla <p1>,<p2>,<p3> -- <command>     Merge multiple .envs into ONE blob
  env-gorilla --list                           Show available projects
  env-gorilla --clear                          Wipe all env blobs from /tmp
  env-gorilla --clear <p1[,p2,...]>            Wipe one (combined) blob

Examples:
  env-gorilla project_x -- python main.py
  env-gorilla llm-docker,slav-ai -- bash       # one master pw → one Touch ID for both
EOF
    exit 1
fi

# ----------------------------------------------------------
# Parse args
# ----------------------------------------------------------
PROJECT="$1"
shift
while [[ "$1" != "--" ]]; do shift; done
shift

# ----------------------------------------------------------
# Fetch env
# ----------------------------------------------------------
echo "env-gorilla: loading $GORILLA_ENV_GROUP/$PROJECT …" >&2
ENV_DATA=$(get_env "$PROJECT")
if [[ -z "$ENV_DATA" ]]; then
    echo "env-gorilla: aborted (no env data)" >&2
    exit 1
fi

# ----------------------------------------------------------
# Parse .env and export
# ----------------------------------------------------------
while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    export "$line"
done <<< "$ENV_DATA"
unset ENV_DATA

echo "env-gorilla: loaded — launching: $*" >&2
exec "$@"
