#!/bin/bash
##########################################################################################
## otp-gorilla - show/copy OTP codes from KeePassXC
## Part of s3c-gorilla
##
## Usage:
##   otp-gorilla              # show all OTP codes
##   otp-gorilla Atlassian    # show + copy specific code
##########################################################################################

DB="$HOME/Library/Mobile Documents/com~apple~CloudDocs/gorilla_tunnel.dat.kdbx"

cat << 'EOF' | ~/bin/colorize.sh -s 1 -e 11
  /$$$$$$  /$$$$$$$$ /$$$$$$$         /$$$$$$   /$$$$$$  /$$$$$$$  /$$$$$$ /$$       /$$        /$$$$$$
 /$$__  $$|__  $$__/| $$__  $$       /$$__  $$ /$$__  $$| $$__  $$|_  $$_/| $$      | $$       /$$__  $$
| $$  \ $$   | $$   | $$  \ $$      | $$  \__/| $$  \ $$| $$  \ $$  | $$  | $$      | $$      | $$  \ $$
| $$  | $$   | $$   | $$$$$$$/      | $$ /$$$$| $$  | $$| $$$$$$$/  | $$  | $$      | $$      | $$$$$$$$
| $$  | $$   | $$   | $$____/       | $$|_  $$| $$  | $$| $$__  $$  | $$  | $$      | $$      | $$__  $$
| $$  | $$   | $$   | $$            | $$  \ $$| $$  | $$| $$  \ $$  | $$  | $$      | $$      | $$  | $$
|  $$$$$$/   | $$   | $$            |  $$$$$$/|  $$$$$$/| $$  | $$ /$$$$$$| $$$$$$$$| $$$$$$$$| $$  | $$
 \______/    |__/   |__/             \______/  \______/ |__/  |__/|______/|________/|________/|__/  |__/
EOF
echo ""
echo "    \033]8;;https://www.youtube.com/watch?v=idx3GSL2KWs\033\\You know the OTP? Yeah you know me!\033]8;;\033\\"
echo ""

PW=$(~/bin/gorilla-touchid 2>/dev/null)
if [[ -z "$PW" ]]; then
    read -s -p "🔐 Master password: " PW
    echo ""
fi

if [[ -z "$1" ]]; then
    echo "🦍 All OTP codes:"
    echo "────────────────────────────────"
    entries=$(printf '%s' "$PW" | keepassxc-cli ls "$DB" "2FA/" -q 2>/dev/null)
    for entry in $entries; do
        code=$(printf '%s' "$PW" | keepassxc-cli show -t "$DB" "2FA/$entry" 2>&1 | grep -oE '[0-9]{6}')
        printf "  %-20s  %s\n" "$entry" "$code"
    done
    echo "────────────────────────────────"
else
    code=$(printf '%s' "$PW" | keepassxc-cli show -t "$DB" "2FA/$1" 2>&1 | grep -oE '[0-9]{6}')
    if [[ -n "$code" ]]; then
        echo "🦍 $1: $code"
        printf '%s' "$code" | pbcopy
        echo "   (copied to clipboard)"
    else
        echo "❌ No OTP found for 2FA/$1"
    fi
fi
unset PW
