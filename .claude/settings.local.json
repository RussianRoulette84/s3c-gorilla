{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(/**)",
      "Edit(/**)",
      "Write(/**)",
      "WebSearch",
      "WebFetch(domain:opencode.ai)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:github.com/sst/opencode)",
      "Bash(*)",
      "Bash(sed *)",
      "Bash(trash *)",
      "Bash(trash-put *)",
      "Bash(gtrash *)"
    ],
    "deny": ["Bash(rm*)"]
  }
}
